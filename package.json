{
  "name": "datadream-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "description": "Offline macOS app for data-driven audio-reactive visuals",
  "author": "DataDream Studio",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist:mac": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "electron": "^27.3.0",
    "ffmpeg-static": "^5.1.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.167.0",
    "xlsx": "^0.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.0",
    "electron-builder": "^24.8.0",
    "typescript": "^5.7.0",
    "vite": "^5.6.0",
    "wait-on": "^7.0.2"
  },
  "build": {
    "appId": "com.datadream.studio",
    "productName": "DataDream Studio",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/ffmpeg-static/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.graphics-design",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "DataDream Studio Installer"
    }
  }
}
